{
  "name": "@asgardeo/expo",
  "version": "0.1.0",
  "description": "Expo implementation of Asgardeo JavaScript SDK.",
  "keywords": [
    "asgardeo",
    "expo",
    "react-native",
    "mobile",
    "authentication"
  ],
  "homepage": "https://github.com/asgardeo/javascript/tree/main/packages/expo#readme",
  "bugs": {
    "url": "https://github.com/asgardeo/javascript/issues"
  },
  "author": "WSO2",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/cjs/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/asgardeo/javascript",
    "directory": "packages/expo"
  },
  "scripts": {
    "build": "pnpm clean && node esbuild.config.mjs && tsc -p tsconfig.lib.json --emitDeclarationOnly --outDir dist",
    "clean": "rimraf dist",
    "fix:lint": "eslint . --ext .js,.jsx,.ts,.tsx,.cjs,.mjs --fix",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.cjs,.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.5",
    "@types/react-native": "^0.73.0",
    "@wso2/eslint-plugin": "catalog:",
    "@wso2/prettier-config": "catalog:",
    "esbuild": "^0.25.9",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "eslint": "8.57.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "jest-environment-node": "^30.1.2",
    "prettier": "^2.6.2",
    "react-native": "^0.81.1",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2"
  },
  "peerDependencies": {
    "@types/react": ">=16.8.0",
    "@types/react-native": ">=0.70.0",
    "expo": ">=49.0.0",
    "react": ">=16.8.0",
    "react-native": ">=0.70.0"
  },
  "dependencies": {
    "expo-auth-session": "~5.5.2",
    "expo-camera": "~15.0.16",
    "expo-crypto": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-secure-store": "~13.0.2",
    "expo-web-browser": "~13.0.3",
    "tslib": "^2.8.1"
  },
  "publishConfig": {
    "access": "public"
  }
}